# ──────────────────────────────────────────────────────────────
# DisperseKit environment — copy to .env and fill in.
# Nothing here is required for local mock tests (`npm run test:contracts`).
# ──────────────────────────────────────────────────────────────

# ---- contracts (Sepolia deploy) ----
# This file (copied to .env at the repo root) is loaded automatically by the
# contracts package; Hardhat "configuration variables" work too:
#   npx hardhat vars set MNEMONIC / INFURA_API_KEY / ETHERSCAN_API_KEY
# A funded account: either PRIVATE_KEY (0x prefix optional; wins if both set)
# or a mnemonic phrase.
PRIVATE_KEY=""
MNEMONIC="test test test test test test test test test test test junk"
# Any Sepolia RPC endpoint (Alchemy/Infura/public). Takes precedence over INFURA_API_KEY.
SEPOLIA_RPC_URL=""
INFURA_API_KEY=""
ETHERSCAN_API_KEY=""
# Sanity check: npx hardhat run scripts/rpc-check.ts --network sepolia

# ---- widget / demo-host (Vite) ----
# Filled in after `npm run deploy:sepolia` in packages/smart-contracts.
VITE_CTOKEN_ADDRESS=""
VITE_DISPERSE_ADDRESS=""
# WalletConnect Cloud project id (free) for RainbowKit wallet options.
VITE_WALLETCONNECT_PROJECT_ID=""
