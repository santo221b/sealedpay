# ──────────────────────────────────────────────────────────────
# DisperseKit environment — copy to .env and fill in.
# Nothing here is required for local mock tests (`npm run test:contracts`).
# ──────────────────────────────────────────────────────────────

# ---- contracts (Sepolia deploy) ----
# The contracts package uses Hardhat "configuration variables" with a
# process.env fallback, so either export these or run:
#   npx hardhat vars set MNEMONIC / INFURA_API_KEY / ETHERSCAN_API_KEY
MNEMONIC="test test test test test test test test test test test junk"
INFURA_API_KEY=""
ETHERSCAN_API_KEY=""

# ---- widget / demo-host (Vite) ----
# Filled in after `npm run deploy:sepolia` in packages/contracts.
VITE_CTOKEN_ADDRESS=""
VITE_DISPERSE_ADDRESS=""
# WalletConnect Cloud project id (free) for RainbowKit wallet options.
VITE_WALLETCONNECT_PROJECT_ID=""
