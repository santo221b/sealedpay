# Supply-chain layers 1 + 6 (see SECURITY.md).
# save-exact: new deps pin "1.2.3", not "^1.2.3" — no surprise drift.
# ignore-scripts: install scripts NEVER run by default (Shai-Hulud kill
# switch); trusted ones are opted in via lavamoat.allowScripts in
# package.json and executed by `npm run setup`.
# NOTE: ignore-scripts also skips npm pre/post run-hooks, so scripts in
# this repo must chain steps explicitly (e.g. compile calls typechain).
save-exact=true
ignore-scripts=true
engine-strict=true
